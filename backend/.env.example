# ------------------------------------------------------------------
# Copy this file to `.env` (local dev) or `.env.docker` (docker-compose)
# and fill in the secrets. Never commit the real file.
# ------------------------------------------------------------------

# --- Database ---
# For local dev (host machine) use `localhost:5437` (mapped port in docker-compose.dev.yml).
# For docker-compose use the service hostname `postgres:5432`.
DATABASE__URL=postgresql+asyncpg://starlink:starlink@postgres:5432/starlink
CHECKPOINT_DB_URL=postgresql://starlink:starlink@postgres:5432/starlink

# --- Auth ---
AUTH__JWT_SECRET_KEY=change-me-in-production
AUTH__JWT_ALGORITHM=HS256
AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- LLM (OpenAI-compatible; works with OpenRouter, Azure, etc.) ---
# Leave OPENAI_API_KEY empty to run the BOM assistant in mock mode.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1

# --- Langfuse tracing (optional; leave empty to disable) ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# --- SMTP (for BOM / escalation emails) ---
SMTP__SERVER=smtp.office365.com
SMTP__PORT=587
SMTP__USERNAME=
SMTP__PASSWORD=

ESCALATION_EMAIL=
BOM_RECIPIENT_EMAIL=

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173

# --- Datasheets directory (product catalog for BOM assistant) ---
# Path is resolved *relative to the backend working dir* (`/app` inside Docker,
# `./backend` on host). The folder must exist and contain the product catalog
# sub-folders: AOC/, DAC/, MPO-MTP/, Media Converter/, QSFP/, SFP/, ...
# In docker-compose the host path `./backend/data` is mounted to `/app/data`,
# so keep the default unless you relocate the catalog.
DATASHEETS_DIR=data/datasheets

# --- Nhanh.vn integration ---
# Required for the BOM agent's product catalog. OAuth flow is triggered by
# visiting `{backend_domain}/api/nhanh/authorize` in a browser.
NHANH__APP_ID=
NHANH__SECRET_KEY=
# Must match the redirect URL registered in the Nhanh app console. For local
# dev, expose the backend via a tunnel (ngrok/cloudflared) and put that URL
# here; Nhanh must be able to reach it over the public internet.
NHANH__REDIRECT_URL=http://localhost:8030/api/nhanh/callback
# Shared secret — Nhanh sends it as the `Authorization` header on webhooks.
NHANH__WEBHOOKS_VERIFY_TOKEN=
